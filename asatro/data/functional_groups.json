{
  "version": 2,
  "_comment": "Functional-group vocabulary for Asatro handle detection. Each group has a 'smarts' (what marks the handle on a fragment) and an optional 'leaving_smarts' (the atoms that do NOT survive into the product when this group reacts). The conserved-core for grow-from-fragment = the fragment minus the leaving atoms (largest connected remnant). Absent/null leaving_smarts means nothing leaves (e.g. an amine N stays; the whole fragment is conserved). 'refinement' classes are subsets of 'parent'.",
  "groups": {
    "primary_amine": {
      "smarts": "[NX3;H2;!$([NX3]C=O);!$([NX3]=*);!$([NX3]S(=O)=O)][#6]",
      "label": "Primary amine",
      "family": "amine"
    },
    "secondary_amine": {
      "smarts": "[NX3;H1;!$([NX3]C=O);!$([NX3]=*);!$([NX3]S(=O)=O)]([#6])[#6]",
      "label": "Secondary amine",
      "family": "amine"
    },
    "carboxylic_acid": {
      "smarts": "[CX3](=O)[OX2H1]",
      "label": "Carboxylic acid",
      "family": "acid",
      "leaving_smarts": "[OX2H1;$([OX2H1][CX3]=O)]"
    },
    "aryl_halide": {
      "smarts": "[c][F,Cl,Br,I]",
      "label": "Aryl/heteroaryl halide",
      "family": "aryl_halide",
      "leaving_smarts": "[F,Cl,Br,I;$([F,Cl,Br,I][c])]"
    },
    "activated_aryl_halide": {
      "smarts": "[F,Cl;$([F,Cl][c]:[c][$([NX3+](=O)[O-]),$([NX3](=O)=O),$([CX2]#[NX1]),$([CX3]=[OX1]),$([SX4](=O)(=O)),$([CX4](F)(F)F)]),$([F,Cl][c]1[c][c]([$([NX3+](=O)[O-]),$([NX3](=O)=O),$([CX2]#[NX1]),$([CX3]=[OX1]),$([SX4](=O)(=O)),$([CX4](F)(F)F)])[c][c][c]1),$([F,Cl][c]1[c][c][c]([$([NX3+](=O)[O-]),$([NX3](=O)=O),$([CX2]#[NX1]),$([CX3]=[OX1]),$([SX4](=O)(=O)),$([CX4](F)(F)F)])[c][c]1),$([F,Cl][c]:[n]),$([F,Cl][c]1[c,n][n][c,n][c,n][c,n]1),$([F,Cl][c]1[c,n][c,n][n][c,n][c,n]1)]",
      "label": "Activated aryl halide (SNAr)",
      "family": "aryl_halide",
      "refinement": true,
      "parent": "aryl_halide",
      "leaving_smarts": "[F,Cl;$([F,Cl][c])]"
    },
    "boronic": {
      "smarts": "[#6][BX3]([OX2])[OX2]",
      "label": "Aryl boronic acid/ester",
      "family": "boronic",
      "leaving_smarts": "[BX3]([OX2])[OX2]"
    },
    "aldehyde": {
      "smarts": "[CX3H1](=O)[#6]",
      "label": "Aldehyde",
      "family": "carbonyl",
      "leaving_smarts": "[OX1;$([OX1]=[CX3H1][#6])]"
    },
    "ketone": {
      "smarts": "[#6][CX3](=O)[#6]",
      "label": "Ketone",
      "family": "carbonyl",
      "leaving_smarts": "[OX1;$([OX1]=[CX3]([#6])[#6])]"
    },
    "sulfonyl_chloride": {
      "smarts": "[SX4](=[OX1])(=[OX1])Cl",
      "label": "Sulfonyl chloride",
