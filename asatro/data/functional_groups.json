      "label": "Organozinc halide",
      "family": "organozinc",
      "leaving_smarts": "[Zn][Cl,Br,I]"
    },
    "phosphonate_ester": {
      "smarts": "[PX4](=[OX1])([OX2][CX4])[OX2][CX4]",
      "label": "Phosphonate ester",
      "family": "phosphonate",
      "leaving_smarts": "[PX4](=[OX1])([OX2][CX4])[OX2][CX4]"
    },
    "alpha_fluoroketone": {
