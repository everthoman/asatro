      "label": "Alpha-keto acid ester",
      "family": "alpha_ketoester"
    },
    "pinacolborane": {
      "smarts": "[BX3H1]1[OX2][CX4]([CX4])([CX4])[CX4]([CX4])([CX4])[OX2]1",
      "label": "Pinacolborane (HBpin)",
      "family": "boronic"
    }
  }
}
